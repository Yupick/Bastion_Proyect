{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Qrypta Cliente Escritorio",
  "version": "0.1.0",
  "identifier": "com.qrypta.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Qrypta Desktop",
        "width": 1100,
        "height": 760,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
